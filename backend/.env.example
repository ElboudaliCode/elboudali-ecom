APP_NAME="Elboudali Ecom"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SEED_DEMO_DATA=false

STORE_NAME="Elboudali Store"
STORE_LEGAL_NAME="Elboudali Store"
STORE_EMAIL=contact@elboudali-store.com
STORE_PHONE=+212600000000
STORE_WHATSAPP=212600000000
STORE_ADDRESS="Casablanca, Maroc"
STORE_CITY=Casablanca
STORE_COUNTRY=Maroc
STORE_ICE=
STORE_RC=
STORE_CURRENCY=MAD
STORE_SUPPORT_HOURS="Lun-Sam, 09:00-18:00"

PAYMENT_PROVIDER=none
PAYMENT_COD_ENABLED=true
PAYMENT_CARD_ENABLED=false
PAYMENT_PAYPAL_ENABLED=false

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=elboudali_ecom
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="votre-adresse@gmail.com"
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="votre-adresse@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
